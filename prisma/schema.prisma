generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
}

model Package {
  package_id   String             @id @default(uuid())
  package_key  String             @unique
  package_name String
  created_at   DateTime           @default(now())
  categories   HardwareCategory[]
  owners       Owner[]

  @@map("packages")
}

model Owner {
  owner_id                   String                    @id @default(uuid())
  full_name                  String
  email                      String                    @unique
  phone                      String                    @unique
  password                   String                    @map("password_hash")
  fcm_token                  String?
  package_id                 String?
  created_at                 DateTime                  @default(now())
  updated_at                 DateTime                  @updatedAt
  status                     OwnerStatus               @default(trial)
  subscription_expires_at    DateTime?
  subscription_reminder_sent Boolean                   @default(false)
  clothingCustomerReturns    ClothingCustomerReturn[]
  clothingNotifications      ClothingNotification[]
  clothingProducts           ClothingProduct[]
  clothingSales              ClothingSales[]
  clothingSupplierReturns    ClothingSupplierReturn[]
  clothingSuppliers          ClothingSupplier[]
  customers                  Customer[]
  groceryCustomerReturns     GroceryCustomerReturn[]
  groceryInventoryLosses     GroceryInventoryLoss[]
  groceryNotifications       GroceryNotification[]
  groceryProducts            GroceryProduct[]
  grocerySales               GrocerySales[]
  groceryStockLots           GroceryStockLot[]
  grocerySupplierReturns     GrocerySupplierReturn[]
  grocerySuppliers           GrocerySupplier[]
  groceryUnits               GroceryUnit[]
  notifications              HardwareNotification[]
  products                   HardwareProduct[]
  stockLots                  HardwareStockLot[]
  stockOuts                  HardwareStockOut[]
  stockOutItems              HardwareStockOutItem[]
  suppliers                  HardwareSupplier[]
  package                    Package?                  @relation(fields: [package_id], references: [package_id], onDelete: Restrict)
  otps                       PasswordResetOtp[]
  paymentProofs              PaymentProof[]
  storeCategories            StoreCategory[]
  storeProducts              StoreProduct[]
  storeSales                 StoreSales[]
  storeSalesItems            StoreSalesItem[]
  storeStockLots             StoreStockLot[]
  storeSupplierReturnItems   StoreSupplierReturnItem[]
  storeSupplierReturns       StoreSupplierReturn[]
  storeSuppliers             StoreSupplier[]
  storeUnits                 StoreUnit[]
  storeCustomerReturns       StoreCustomerReturn[]
  storeCustomerReturnItems  StoreCustomerReturnItem[] 

  @@map("owners")
}

model PasswordResetOtp {
  id             String    @id @default(uuid())
  owner_id       String
  email          String
  otp_hash       String
  expires_at     DateTime
  wrong_attempts Int       @default(0)
  locked_until   DateTime?
  last_sent_at   DateTime?
  verified_at    DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  owner          Owner     @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)

  @@index([owner_id])
  @@index([email])
  @@index([expires_at])
  @@map("password_reset_otps")
}

model RegistrationOtp {
  id             String    @id @default(uuid())
  email          String
  otp_hash       String
  expires_at     DateTime
  wrong_attempts Int       @default(0)
  locked_until   DateTime?
  last_sent_at   DateTime?
  verified_at    DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  full_name      String?
  phone          String?
  password_hash  String?
  package_key    String?

  @@index([email])
  @@index([expires_at])
  @@map("registration_otps")
}

model HardwareSupplier {
  supplier_id   String             @id @default(uuid())
  owner_id      String
  supplier_name String
  phone         String
  email         String?
  address       String?
  created_at    DateTime           @default(now())
  stockLots     HardwareStockLot[]
  owner         Owner              @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)

  @@unique([owner_id, phone])
  @@map("hardware_suppliers")
}

model HardwareCategory {
  category_id   String            @id @default(uuid())
  package_id    String
  category_name String
  created_at    DateTime          @default(now())
  updated_at    DateTime          @updatedAt
  package       Package           @relation(fields: [package_id], references: [package_id], onDelete: Cascade)
  products      HardwareProduct[]

  @@unique([package_id, category_name])
  @@map("hardware_categories")
}

model HardwareProduct {
  product_id                 String                 @id @default(uuid())
  owner_id                   String
  category_id                String
  product_name               String
  created_at                 DateTime               @default(now())
  updated_at                 DateTime               @updatedAt
  last_low_stock_notified_at DateTime?
  notifications              HardwareNotification[]
  category                   HardwareCategory       @relation(fields: [category_id], references: [category_id])
  owner                      Owner                  @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  stockLots                  HardwareStockLot[]
  stockOutItems              HardwareStockOutItem[]

  @@unique([owner_id, product_name])
  @@map("hardware_products")
}

model HardwareStockLot {
  lot_id        String                 @id @default(uuid())
  owner_id      String
  product_id    String
  supplier_id   String
  cp            Decimal                @db.Decimal(10, 2)
  sp            Decimal                @db.Decimal(10, 2)
  qty_in        Int
  qty_remaining Int
  notes         String?
  created_at    DateTime               @default(now())
  owner         Owner                  @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  product       HardwareProduct        @relation(fields: [product_id], references: [product_id], onDelete: Cascade)
  supplier      HardwareSupplier       @relation(fields: [supplier_id], references: [supplier_id])
  stockOutItems HardwareStockOutItem[]

  @@index([owner_id, product_id])
  @@index([owner_id, supplier_id])
  @@map("hardware_stock_lots")
}

model HardwareStockOut {
  stockout_id         String                 @id @default(uuid())
  owner_id            String
  payment_status      String                 @default("pending")
  total_amount        Decimal                @db.Decimal(10, 2)
  paid_amount         Decimal                @db.Decimal(10, 2)
  note                String?
  created_at          DateTime               @default(now())
  customer_address    String?
  customer_name       String?
  customer_phn_number String?
  discount            Decimal                @default(0) @db.Decimal(10, 2)
  owner               Owner                  @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  items               HardwareStockOutItem[]

  @@index([owner_id])
  @@map("hardware_stock_out")
}

model HardwareStockOutItem {
  stockout_item_id String           @id @default(uuid())
  owner_id         String
  stockout_id      String
  product_id       String
  lot_id           String
  qty              Int
  cp               Decimal          @db.Decimal(10, 2)
  sp               Decimal          @db.Decimal(10, 2)
  note             String?
  line_total       Decimal          @db.Decimal(10, 2)
  created_at       DateTime         @default(now())
  lot              HardwareStockLot @relation(fields: [lot_id], references: [lot_id])
  owner            Owner            @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  product          HardwareProduct  @relation(fields: [product_id], references: [product_id])
  stockout         HardwareStockOut @relation(fields: [stockout_id], references: [stockout_id], onDelete: Cascade)

  @@index([owner_id, stockout_id])
  @@index([owner_id, product_id])
  @@index([owner_id, lot_id])
  @@map("hardware_stock_out_items")
}

model HardwareNotification {
  notification_id String           @id @default(uuid())
  owner_id        String
  type            String
  title           String
  message         String
  product_id      String?
  read_at         DateTime?
  created_at      DateTime         @default(now())
  is_enabled      Boolean          @default(true)
  owner           Owner            @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  product         HardwareProduct? @relation(fields: [product_id], references: [product_id])

  @@index([owner_id, created_at])
  @@index([owner_id, read_at])
  @@map("hardware_notifications")
}

model ClothingCategory {
  category_id   String            @id @default(uuid())
  category_name String            @unique
  created_at    DateTime          @default(now())
  updated_at    DateTime          @updatedAt
  products      ClothingProduct[]

  @@map("clothing_categories")
}

model ClothingSize {
  size_id    String              @id @default(uuid())
  size_name  String              @unique
  salesItems ClothingSalesItem[]
  stockLots  ClothingStockLot[]

  @@map("clothing_sizes")
}

model ClothingColor {
  color_id   String              @id @default(uuid())
  color_name String              @unique
  salesItems ClothingSalesItem[]
  stockLots  ClothingStockLot[]

  @@map("clothing_colors")
}

model ClothingProduct {
  product_id                 String                 @id @default(uuid())
  owner_id                   String
  category_id                String
  product_name               String
  created_at                 DateTime               @default(now())
  updated_at                 DateTime               @updatedAt
  last_low_stock_notified_at DateTime?
  clothingNotifications      ClothingNotification[]
  category                   ClothingCategory       @relation(fields: [category_id], references: [category_id])
  owner                      Owner                  @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  salesItems                 ClothingSalesItem[]
  stockLots                  ClothingStockLot[]

  @@unique([owner_id, product_name])
  @@index([owner_id, category_id])
  @@map("clothing_products")
}

model ClothingSupplier {
  supplier_id   String                   @id @default(uuid())
  owner_id      String
  supplier_name String
  phone         String
  email         String?
  address       String?
  created_at    DateTime                 @default(now())
  stockLots     ClothingStockLot[]
  returns       ClothingSupplierReturn[]
  owner         Owner                    @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)

  @@unique([owner_id, phone])
  @@map("clothing_suppliers")
}

model ClothingStockLot {
  lot_id              String                       @id @default(uuid())
  product_id          String
  supplier_id         String
  size_id             String
  color_id            String
  cp                  Decimal                      @db.Decimal(10, 2)
  sp                  Decimal                      @db.Decimal(10, 2)
  qty_in              Int
  qty_remaining       Int
  notes               String?
  created_at          DateTime                     @default(now())
  barcode             String?                      @unique
  barcode_image_url   String?
  customerReturnItems ClothingCustomerReturnItem[]
  salesItems          ClothingSalesItem[]
  color               ClothingColor                @relation(fields: [color_id], references: [color_id])
  product             ClothingProduct              @relation(fields: [product_id], references: [product_id], onDelete: Cascade)
  size                ClothingSize                 @relation(fields: [size_id], references: [size_id])
  supplier            ClothingSupplier             @relation(fields: [supplier_id], references: [supplier_id])
  supplierReturnItems ClothingSupplierReturnItem[]

  @@index([product_id])
  @@index([supplier_id])
  @@index([product_id, size_id, color_id])
  @@map("clothing_stock_lots")
}

model ClothingSales {
  sales_id        String                   @id @default(uuid())
  owner_id        String
  customer_id     String?
  payment_status  String                   @default("pending")
  total_amount    Decimal                  @db.Decimal(10, 2)
  paid_amount     Decimal                  @db.Decimal(10, 2)
  note            String?
  created_at      DateTime                 @default(now())
  discount        Decimal                  @default(0) @db.Decimal(10, 2)
  updated_at      DateTime                 @default(now()) @updatedAt
  customerReturns ClothingCustomerReturn[]
  customer        Customer?                @relation(fields: [customer_id], references: [customer_id])
  owner           Owner                    @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  items           ClothingSalesItem[]

  @@index([owner_id, created_at])
  @@index([customer_id])
  @@map("clothing_sales")
}

model ClothingSalesItem {
  sales_item_id       String                       @id @default(uuid())
  sales_id            String
  product_id          String
  lot_id              String
  size_id             String
  color_id            String
  qty                 Int
  cp                  Decimal                      @db.Decimal(10, 2)
  sp                  Decimal                      @db.Decimal(10, 2)
  line_total          Decimal                      @db.Decimal(10, 2)
  note                String?
  created_at          DateTime                     @default(now())
  returned_qty        Int                          @default(0)
  customerReturnItems ClothingCustomerReturnItem[]
  color               ClothingColor                @relation(fields: [color_id], references: [color_id])
  lot                 ClothingStockLot             @relation(fields: [lot_id], references: [lot_id])
  product             ClothingProduct              @relation(fields: [product_id], references: [product_id])
  sales               ClothingSales                @relation(fields: [sales_id], references: [sales_id], onDelete: Cascade)
  size                ClothingSize                 @relation(fields: [size_id], references: [size_id])

  @@index([sales_id])
  @@index([product_id])
  @@index([lot_id])
  @@map("clothing_sales_items")
}

model Customer {
  customer_id  String          @id @default(uuid())
  owner_id     String
  full_name    String
  phone        String?
  email        String?
  address      String?
  created_at   DateTime        @default(now())
  updated_at   DateTime        @updatedAt
  sales        ClothingSales[]
  owner        Owner           @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  grocerySales GrocerySales[]
  storeSales   StoreSales[]

  @@unique([owner_id, phone])
  @@index([owner_id])
  @@map("customers")
}

model ClothingCustomerReturn {
  return_id     String                       @id @default(uuid())
  owner_id      String
  sales_id      String?
  refund_amount Decimal?                     @db.Decimal(10, 2)
  note          String?
  created_at    DateTime                     @default(now())
  items         ClothingCustomerReturnItem[]
  owner         Owner                        @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  sales         ClothingSales?               @relation(fields: [sales_id], references: [sales_id])

  @@index([owner_id, created_at])
  @@map("clothing_customer_returns")
}

model ClothingCustomerReturnItem {
  return_item_id String                 @id @default(uuid())
  return_id      String
  sales_item_id  String?
  lot_id         String
  qty            Int
  condition      String                 @default("good")
  note           String?
  created_at     DateTime               @default(now())
  amount         Decimal                @db.Decimal(10, 2)
  lot            ClothingStockLot       @relation(fields: [lot_id], references: [lot_id])
  return         ClothingCustomerReturn @relation(fields: [return_id], references: [return_id], onDelete: Cascade)
  salesItem      ClothingSalesItem?     @relation(fields: [sales_item_id], references: [sales_item_id])

  @@index([return_id])
  @@index([lot_id])
  @@map("clothing_customer_return_items")
}

model ClothingSupplierReturn {
  return_id   String                       @id @default(uuid())
  owner_id    String
  supplier_id String
  status      String                       @default("pending")
  note        String?
  created_at  DateTime                     @default(now())
  amount      Decimal                      @db.Decimal(10, 2)
  items       ClothingSupplierReturnItem[]
  owner       Owner                        @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  supplier    ClothingSupplier             @relation(fields: [supplier_id], references: [supplier_id])

  @@index([owner_id, created_at])
  @@index([owner_id, supplier_id])
  @@map("clothing_supplier_returns")
}

model ClothingSupplierReturnItem {
  return_item_id String                 @id @default(uuid())
  return_id      String
  lot_id         String
  qty            Int
  reason         String?
  note           String?
  created_at     DateTime               @default(now())
  lot            ClothingStockLot       @relation(fields: [lot_id], references: [lot_id])
  return         ClothingSupplierReturn @relation(fields: [return_id], references: [return_id], onDelete: Cascade)

  @@index([return_id])
  @@index([lot_id])
  @@map("clothing_supplier_return_items")
}

model ClothingNotification {
  notification_id String           @id @default(uuid())
  owner_id        String
  type            String
  title           String
  message         String
  product_id      String?
  read_at         DateTime?
  created_at      DateTime         @default(now())
  is_enabled      Boolean          @default(true)
  owner           Owner            @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  product         ClothingProduct? @relation(fields: [product_id], references: [product_id])

  @@index([owner_id, created_at])
  @@index([owner_id, read_at])
  @@map("clothing_notifications")
}

model PaymentQRStore {
  id            String   @id @default(uuid())
  qr_image_path String
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("payment_qr_store")
}

model PaymentProof {
  id          String    @id @default(uuid())
  owner_id    String
  image_url   String
  status      String    @default("pending")
  note        String?
  reviewed_at DateTime?
  created_at  DateTime  @default(now())
  owner       Owner     @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)

  @@index([owner_id])
  @@index([status])
  @@map("payment_proofs")
}

model GrocerySupplier {
  supplier_id   String                  @id @default(uuid())
  owner_id      String
  supplier_name String
  phone         String
  email         String?
  address       String?
  created_at    DateTime                @default(now())
  updated_at    DateTime                @updatedAt
  deleted_at    DateTime?
  stockLots     GroceryStockLot[]
  returns       GrocerySupplierReturn[]
  owner         Owner                   @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)

  @@unique([owner_id, phone])
  @@index([deleted_at])
  @@index([updated_at])
  @@map("grocery_suppliers")
}

model GroceryCategory {
  category_id   String           @id @default(uuid())
  category_name String           @unique
  created_at    DateTime         @default(now())
  updated_at    DateTime         @updatedAt
  deleted_at    DateTime?
  products      GroceryProduct[]

  @@index([deleted_at])
  @@index([updated_at])
  @@map("grocery_categories")
}

model GroceryBrand {
  brand_id   String           @id @default(uuid())
  brand_name String           @unique
  created_at DateTime         @default(now())
  updated_at DateTime         @updatedAt
  deleted_at DateTime?
  products   GroceryProduct[]

  @@index([deleted_at])
  @@index([updated_at])
  @@map("grocery_brands")
}

model GroceryUnit {
  unit_id    String           @id @default(uuid())
  owner_id   String
  unit_name  String
  created_at DateTime         @default(now())
  updated_at DateTime         @updatedAt
  deleted_at DateTime?
  products   GroceryProduct[]
  owner      Owner            @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)

  @@unique([owner_id, unit_name])
  @@index([owner_id])
  @@index([deleted_at])
  @@index([updated_at])
  @@map("grocery_units")
}

model GroceryProduct {
  product_id                 String                 @id @default(uuid())
  owner_id                   String
  category_id                String?
  brand_id                   String?
  unit_id                    String
  product_name               String
  created_at                 DateTime               @default(now())
  updated_at                 DateTime               @updatedAt
  deleted_at                 DateTime?
  last_low_stock_notified_at DateTime?
  barcode                    String?                @unique
  description                String?
  losses                     GroceryInventoryLoss[]
  notifications              GroceryNotification[]
  brand                      GroceryBrand?          @relation(fields: [brand_id], references: [brand_id])
  category                   GroceryCategory?       @relation(fields: [category_id], references: [category_id])
  owner                      Owner                  @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  unit                       GroceryUnit            @relation(fields: [unit_id], references: [unit_id])
  salesItems                 GrocerySalesItem[]
  stockLots                  GroceryStockLot[]

  @@unique([owner_id, product_name])
  @@index([owner_id, category_id])
  @@index([owner_id, brand_id])
  @@index([owner_id, unit_id])
  @@index([deleted_at])
  @@index([updated_at])
  @@map("grocery_products")
}

model GroceryStockLot {
  lot_id              String                      @id @default(uuid())
  product_id          String
  supplier_id         String
  cp                  Decimal                     @db.Decimal(10, 2)
  sp                  Decimal                     @db.Decimal(10, 2)
  qty_in              Decimal                     @db.Decimal(10, 3)
  qty_remaining       Decimal                     @db.Decimal(10, 3)
  expiry_date         DateTime?
  notes               String?
  created_at          DateTime                    @default(now())
  updated_at          DateTime                    @updatedAt
  deleted_at          DateTime?
  barcode             String?                     @unique
  barcode_image_url   String?
  batch_no            String?
  owner_id            String
  customerReturnItems GroceryCustomerReturnItem[]
  losses              GroceryInventoryLoss[]
  salesItems          GrocerySalesItem[]
  owner               Owner                       @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  product             GroceryProduct              @relation(fields: [product_id], references: [product_id], onDelete: Cascade)
  supplier            GrocerySupplier             @relation(fields: [supplier_id], references: [supplier_id])
  returnItems         GrocerySupplierReturnItem[]

  @@index([owner_id, product_id])
  @@index([owner_id, supplier_id])
  @@index([deleted_at])
  @@index([updated_at])
  @@map("grocery_stock_lots")
}

model GrocerySupplierReturn {
  return_id    String                      @id @default(uuid())
  owner_id     String
  supplier_id  String
  total_refund Decimal                     @db.Decimal(10, 2)
  amount       Decimal                     @db.Decimal(10, 2)
  note         String?
  created_at   DateTime                    @default(now())
  items        GrocerySupplierReturnItem[]
  owner        Owner                       @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  supplier     GrocerySupplier             @relation(fields: [supplier_id], references: [supplier_id])

  @@index([owner_id, created_at])
  @@index([owner_id, supplier_id])
  @@map("grocery_supplier_returns")
}

model GrocerySupplierReturnItem {
  return_item_id String                @id @default(uuid())
  return_id      String
  lot_id         String
  qty            Decimal               @db.Decimal(10, 3)
  refund_amount  Decimal               @db.Decimal(10, 2)
  reason         String?
  note           String?
  created_at     DateTime              @default(now())
  lot            GroceryStockLot       @relation(fields: [lot_id], references: [lot_id])
  return         GrocerySupplierReturn @relation(fields: [return_id], references: [return_id], onDelete: Cascade)

  @@index([return_id])
  @@index([lot_id])
  @@map("grocery_supplier_return_items")
}

model GroceryInventoryLoss {
  loss_id     String          @id @default(uuid())
  owner_id    String
  lot_id      String
  product_id  String
  qty         Decimal         @db.Decimal(10, 3)
  cp          Decimal         @db.Decimal(10, 2)
  loss_amount Decimal         @db.Decimal(10, 2)
  reason      String
  note        String?
  created_at  DateTime        @default(now())
  lot         GroceryStockLot @relation(fields: [lot_id], references: [lot_id])
  owner       Owner           @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  product     GroceryProduct  @relation(fields: [product_id], references: [product_id])

  @@index([owner_id])
  @@index([created_at])
  @@index([reason])
  @@index([product_id])
  @@map("grocery_inventory_losses")
}

model GrocerySales {
  sales_id       String                  @id @default(uuid())
  owner_id       String
  customer_id    String?
  payment_status String                  @default("pending")
  total_amount   Decimal                 @db.Decimal(10, 2)
  discount       Decimal                 @default(0) @db.Decimal(10, 2)
  paid_amount    Decimal                 @db.Decimal(10, 2)
  note           String?
  created_at     DateTime                @default(now())
  updated_at     DateTime                @updatedAt
  deleted_at     DateTime?
  returns        GroceryCustomerReturn[]
  customer       Customer?               @relation(fields: [customer_id], references: [customer_id])
  owner          Owner                   @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  items          GrocerySalesItem[]

  @@index([owner_id, created_at])
  @@index([customer_id])
  @@index([deleted_at])
  @@index([updated_at])
  @@map("grocery_sales")
}

model GrocerySalesItem {
  sales_item_id String                      @id @default(uuid())
  sales_id      String
  product_id    String
  lot_id        String
  qty           Decimal                     @db.Decimal(10, 3)
  cp            Decimal                     @db.Decimal(10, 2)
  sp            Decimal                     @db.Decimal(10, 2)
  line_total    Decimal                     @db.Decimal(10, 2)
  note          String?
  created_at    DateTime                    @default(now())
  returned_qty  Decimal                     @default(0) @db.Decimal(10, 3)
  returnItems   GroceryCustomerReturnItem[]
  lot           GroceryStockLot             @relation(fields: [lot_id], references: [lot_id])
  product       GroceryProduct              @relation(fields: [product_id], references: [product_id])
  sales         GrocerySales                @relation(fields: [sales_id], references: [sales_id], onDelete: Cascade)

  @@index([sales_id])
  @@index([product_id])
  @@index([lot_id])
  @@map("grocery_sales_items")
}

model GroceryCustomerReturn {
  return_id     String                      @id @default(uuid())
  owner_id      String
  sales_id      String
  refund_amount Decimal                     @db.Decimal(10, 2)
  note          String?
  created_at    DateTime                    @default(now())
  deleted_at    DateTime?
  updated_at    DateTime                    @updatedAt
  items         GroceryCustomerReturnItem[]
  owner         Owner                       @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  sales         GrocerySales                @relation(fields: [sales_id], references: [sales_id])

  @@index([owner_id, created_at])
  @@index([sales_id])
  @@index([deleted_at])
  @@index([updated_at])
  @@map("grocery_customer_returns")
}

model GroceryCustomerReturnItem {
  return_item_id String                @id @default(uuid())
  return_id      String
  sales_item_id  String
  lot_id         String
  qty            Decimal               @db.Decimal(10, 3)
  note           String?
  created_at     DateTime              @default(now())
  amount         Decimal?              @db.Decimal(10, 2)
  lot            GroceryStockLot       @relation(fields: [lot_id], references: [lot_id])
  return         GroceryCustomerReturn @relation(fields: [return_id], references: [return_id], onDelete: Cascade)
  salesItem      GrocerySalesItem      @relation(fields: [sales_item_id], references: [sales_item_id])

  @@index([return_id])
  @@index([sales_item_id])
  @@index([lot_id])
  @@map("grocery_customer_return_items")
}

model GroceryNotification {
  notification_id String          @id @default(uuid())
  owner_id        String
  type            String
  title           String
  message         String
  product_id      String?
  read_at         DateTime?
  created_at      DateTime        @default(now())
  is_enabled      Boolean         @default(true)
  owner           Owner           @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  product         GroceryProduct? @relation(fields: [product_id], references: [product_id])

  @@index([owner_id, created_at])
  @@index([owner_id, read_at])
  @@index([owner_id, is_enabled])
  @@map("grocery_notifications")
}

model SyncIdempotency {
  id             String   @id @default(uuid())
  owner_id       String
  entity_type    String
  local_id       String
  server_id      String
  created_at     DateTime @default(now())
  operation      String   @default("create")
  last_synced_at DateTime @default(now()) @updatedAt

  @@unique([owner_id, entity_type, local_id])
  @@index([owner_id, entity_type])
  @@index([last_synced_at])
  @@map("sync_idempotency")
}

model StoreCategory {
  category_id   String         @id @default(uuid())
  owner_id      String
  category_name String
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  owner         Owner          @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  products      StoreProduct[]

  @@unique([owner_id, category_name])
  @@index([owner_id])
  @@map("store_categories")
}

model StoreUnit {
  unit_id    String         @id @default(uuid())
  owner_id   String
  unit_name  String
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt
  products   StoreProduct[]
  owner      Owner          @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)

  @@unique([owner_id, unit_name])
  @@index([owner_id])
  @@map("store_units")
}

model StoreSupplier {
  supplier_id    String                     @id @default(uuid())
  owner_id       String
  supplier_name  String
  phone          String
  email          String?
  address        String?
  created_at     DateTime                   @default(now())
  updated_at     DateTime                   @updatedAt
  due_amount     Decimal                    @default(0) @db.Decimal(10, 2)
  paid_amount    Decimal                    @default(0) @db.Decimal(10, 2)
  payment_status StoreSupplierPaymentStatus @default(paid)
  stockLots      StoreStockLot[]
  returns        StoreSupplierReturn[]
  owner          Owner                      @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)

  @@unique([owner_id, phone])
  @@index([owner_id])
  @@map("store_suppliers")
}

model StoreProduct {
  product_id   String           @id @default(uuid())
  owner_id     String
  category_id  String?
  unit_id      String?
  product_name String
  description  String?
  created_at   DateTime         @default(now())
  updated_at   DateTime         @updatedAt
  cp           Decimal?         @db.Decimal(10, 2)
  sp           Decimal?         @db.Decimal(10, 2)
  type         StoreProductType @default(item)
  category     StoreCategory?   @relation(fields: [category_id], references: [category_id])
  owner        Owner            @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  unit         StoreUnit?       @relation(fields: [unit_id], references: [unit_id])
  salesItems   StoreSalesItem[]
  stockLots    StoreStockLot[]

  @@unique([owner_id, product_name])
  @@index([owner_id])
  @@index([owner_id, category_id])
  @@index([owner_id, type])
  @@map("store_products")
}

model StoreStockLot {
  lot_id              String                    @id @default(uuid())
  owner_id            String
  product_id          String
  supplier_id         String
  cp                  Decimal                   @db.Decimal(10, 2)
  sp                  Decimal                   @db.Decimal(10, 2)
  qty_in              Int
  qty_remaining       Int
  notes               String?
  created_at          DateTime                  @default(now())
  updated_at          DateTime                  @updatedAt
  salesItems          StoreSalesItem[]
  owner               Owner                     @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  product             StoreProduct              @relation(fields: [product_id], references: [product_id], onDelete: Cascade)
  supplier            StoreSupplier             @relation(fields: [supplier_id], references: [supplier_id])
  supplierReturnItems StoreSupplierReturnItem[]
  customerReturnItems StoreCustomerReturnItem[]

  @@index([owner_id, product_id])
  @@index([owner_id, supplier_id])
  @@map("store_stock_lots")
}

model StoreSupplierReturn {
  return_id    String                    @id @default(uuid())
  owner_id     String
  supplier_id  String
  note         String?
  created_at   DateTime                  @default(now())
  total_refund Decimal                   @db.Decimal(10, 2)
  items        StoreSupplierReturnItem[]
  owner        Owner                     @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  supplier StoreSupplier @relation(fields: [supplier_id], references: [supplier_id], onDelete: Restrict)

  @@index([owner_id, created_at])
  @@index([owner_id, supplier_id])
  @@map("store_supplier_returns")
}

model StoreSupplierReturnItem {
  return_id      String
  lot_id         String
  qty            Int
  reason         String?
  note           String?
  created_at     DateTime            @default(now())
  refund_amount  Decimal             @db.Decimal(10, 2)
  return_item_id String              @id @default(uuid())
  owner_id       String
  lot            StoreStockLot       @relation(fields: [lot_id], references: [lot_id])
  owner          Owner               @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  return         StoreSupplierReturn @relation(fields: [return_id], references: [return_id], onDelete: Cascade)

  @@index([return_id])
  @@index([owner_id])
  @@index([lot_id])
  @@map("store_supplier_return_items")
}

model StoreSales {
  sales_id       String                  @id @default(uuid())
  owner_id       String
  customer_id    String?
  total_amount   Decimal                 @db.Decimal(10, 2)
  discount       Decimal                 @default(0) @db.Decimal(10, 2)
  paid_amount    Decimal                 @default(0) @db.Decimal(10, 2)
  note           String?
  created_at     DateTime                @default(now())
  updated_at     DateTime                @updatedAt
  payment_status StoreSalesPaymentStatus @default(pending)
  due_amount     Decimal                 @default(0) @db.Decimal(10, 2)
  payment_method StorePaymentMethod @default(cash)
  customer       Customer?               @relation(fields: [customer_id], references: [customer_id])
  owner          Owner                   @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  items          StoreSalesItem[]
  customerReturns StoreCustomerReturn[]

  @@index([owner_id, created_at])
  @@index([customer_id])
  @@map("store_sales")
}

model StoreSalesItem {
  sales_item_id String         @id @default(uuid())
  sales_id      String
  product_id    String
  lot_id        String?
  qty           Int
  returned_qty  Int            @default(0)
  cp            Decimal?       @db.Decimal(10, 2)
  sp            Decimal        @db.Decimal(10, 2)
  line_total    Decimal        @db.Decimal(10, 2)
  note          String?
  created_at    DateTime       @default(now())
  owner_id      String
  lot           StoreStockLot? @relation(fields: [lot_id], references: [lot_id])
  owner         Owner          @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  product       StoreProduct   @relation(fields: [product_id], references: [product_id])
  sales         StoreSales     @relation(fields: [sales_id], references: [sales_id], onDelete: Cascade)
  returnItems   StoreCustomerReturnItem[]

  @@index([sales_id])
  @@index([owner_id])
  @@index([product_id])
  @@index([lot_id])
  @@map("store_sales_items")
}

model StoreCustomerReturn {
  return_id     String                    @id @default(uuid())
  owner_id      String
  sales_id      String
  refund_amount Decimal                   @db.Decimal(10, 2)
  note          String?
  created_at    DateTime                  @default(now())
  items         StoreCustomerReturnItem[]
  owner         Owner                     @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)
  sales StoreSales @relation(fields: [sales_id], references: [sales_id], onDelete: Restrict)

  @@index([owner_id, created_at])
  @@index([sales_id])
  @@map("store_customer_returns")
}

model StoreCustomerReturnItem {
  return_item_id String             @id @default(uuid())
  owner_id      String              
  return_id      String
  sales_item_id  String
  lot_id         String
  qty            Int
  amount         Decimal             @db.Decimal(10, 2)
  note           String?
  created_at     DateTime            @default(now())
  return         StoreCustomerReturn @relation(fields: [return_id], references: [return_id], onDelete: Cascade)
  salesItem      StoreSalesItem      @relation(fields: [sales_item_id], references: [sales_item_id])
  lot            StoreStockLot       @relation(fields: [lot_id], references: [lot_id])
  owner         Owner    @relation(fields: [owner_id], references: [owner_id], onDelete: Cascade)

  @@index([return_id])
  @@index([sales_item_id])
  @@index([lot_id])
  @@map("store_customer_return_items")
}

enum OwnerStatus {
  trial
  active
  inactive

  @@map("owner_status")
}

enum StoreSupplierPaymentStatus {
  unpaid
  partial
  paid

  @@map("store_supplier_payment_status")
}

enum StoreProductType {
  item
  service

  @@map("store_product_type")
}

enum StoreSalesPaymentStatus {
  pending
  partial
  paid

  @@map("store_sales_payment_status")
}
enum StorePaymentMethod {
  cash
  online

  @@map("store_payment_method")
}